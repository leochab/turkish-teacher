{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "mastery-db.schema.json",
  "title": "Mastery DB",
  "description": "Per-skill mastery levels and history.",
  "type": "object",
  "required": ["version", "updated", "skills"],
  "additionalProperties": false,
  "properties": {
    "version": { "type": "string" },
    "updated": {
      "oneOf": [
        { "type": "null" },
        { "type": "string", "format": "date", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" }
      ]
    },
    "skills": {
      "type": "object",
      "required": ["speaking", "reading", "writing", "grammar", "vocabulary"],
      "additionalProperties": false,
      "properties": {
        "speaking":   { "$ref": "#/$defs/skill" },
        "reading":    { "$ref": "#/$defs/skill" },
        "writing":    { "$ref": "#/$defs/skill" },
        "grammar":    { "$ref": "#/$defs/skill" },
        "vocabulary": { "$ref": "#/$defs/skill" }
      }
    }
  },
  "$defs": {
    "skill": {
      "type": "object",
      "required": ["level", "history"],
      "additionalProperties": false,
      "properties": {
        "level": { "type": "integer", "minimum": 0, "maximum": 5 },
        "history": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["date", "level"],
            "additionalProperties": false,
            "properties": {
              "date":  { "type": "string", "format": "date", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
              "level": { "type": "integer", "minimum": 0, "maximum": 5 }
            }
          }
        }
      }
    }
  }
}
